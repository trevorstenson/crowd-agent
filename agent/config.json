{
  "model": "moonshotai/kimi-k2-instruct-0905",
  "max_tokens": 8096,
  "max_turns": 10,
  "temperature": 0,
  "error_handling": {
    "max_retries": 3,
    "initial_retry_delay_seconds": 1,
    "max_retry_delay_seconds": 30,
    "backoff_multiplier": 2,
    "agent_loop_timeout_seconds": 300,
    "tool_execution_timeout_seconds": 60
  },
  "chaining": {
    "max_chain_depth": 15
  },
  "failure_tracking": {
    "enabled": true,
    "auto_categorize": true,
    "report_frequency": "run",
    "persist_failures": true,
    "max_stored_failures": 1000
  }
}
